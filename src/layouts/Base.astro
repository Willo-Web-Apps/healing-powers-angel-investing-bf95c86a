---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "HPAI Capital — Invest in the Future of Human Flourishing", description = "HPAI Capital is the world's first tokenized impact angel fund. On-chain RWA tokens representing LP interests in a regulated fund backing AI, blockchain, and health ventures that advance human consciousness and abundance." } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "HPAI Capital",
      "description": "HPAI Capital is the world's first tokenized impact angel fund. On-chain RWA tokens representing LP interests in a regulated fund backing AI, blockchain, and health ventures that advance human consciousness and abundance.",
      "url": "https://healing-powers-angel-investing.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
