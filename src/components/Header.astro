---
<header class="sticky top-0 z-50 border-b border-surface-300/10" style="background: oklch(0.11 0.012 255 / 0.85); backdrop-filter: blur(20px) saturate(1.3);">
  <nav class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 h-16 flex items-center justify-between">

    <!-- Wordmark -->
    <a href="/" class="flex items-center gap-3 group">
      <!-- Monogram mark -->
      <div class="w-7 h-7 border border-brand-500/50 flex items-center justify-center flex-shrink-0 group-hover:border-brand-500 transition-colors duration-200">
        <span class="font-display text-brand-500 text-xs" style="font-weight:600; letter-spacing:0.05em;">HP</span>
      </div>
      <span class="font-display text-surface-950 text-base tracking-wide" style="font-weight:600; letter-spacing:0.04em;">HPAI <span class="text-brand-500">Capital</span></span>
    </a>

    <!-- Nav links -->
    <div class="hidden md:flex items-center gap-8">
      <a href="#thesis" class="font-body font-400 text-sm text-surface-900 hover:text-brand-500 transition-colors duration-150" style="letter-spacing:0.04em;">Thesis</a>
      <a href="#pillars" class="font-body font-400 text-sm text-surface-900 hover:text-brand-500 transition-colors duration-150" style="letter-spacing:0.04em;">Pillars</a>
      <a href="#structure" class="font-body font-400 text-sm text-surface-900 hover:text-brand-500 transition-colors duration-150" style="letter-spacing:0.04em;">Structure</a>
      <a href="#who" class="font-body font-400 text-sm text-surface-900 hover:text-brand-500 transition-colors duration-150" style="letter-spacing:0.04em;">Who We Serve</a>
    </div>

    <!-- CTA -->
    <a
      href="#apply"
      class="inline-flex items-center gap-2 px-5 py-2.5 border border-brand-500/50 hover:border-brand-500 text-brand-500 hover:bg-brand-500/10 font-body font-500 text-sm tracking-wide transition-all duration-200"
      style="letter-spacing:0.08em;"
    >
      REQUEST ACCESS
    </a>

  </nav>
</header>
