---
import Base from '../layouts/Base.astro';
---
<Base title="Your New Business" description="**HPAI (Healing Powers Angel Investing)** is a proposed tokenized impact angel fund focused on backing early-stage AI and blockchain projects aligned with human health, consciousness, and abundance. The fund issues on-chain RWA (real-world asset) tokens representing LP interests in a regulated investment vehicle, offering investors fractional ownership, transparency, and potential secondary liquidity while targeting deals that demonstrate both financial return and measurable positive impact. HPAI differentiates itself through three core pillars — frontier AI/blockchain, human health & wellness, and positive media/narrative — using AI-assisted sourcing and due diligence, programmable impact covenants, and a community-driven go-to-market strategy targeting crypto-savvy angels, conscious capital allocators, and Web3 participants who want a compliant, purpose-driven co-investment structure for the emerging intersection of tokenization and impact investing.">
  <!-- Hero — the Product Agent will replace this entire page -->
  <section class="relative min-h-[80vh] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-500/5 via-surface-50 to-brand-500/10"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-7xl font-extrabold tracking-tight text-surface-900 font-display max-w-4xl mx-auto leading-[1.1] animate-slide-up">
        Your New Business
      </h1>
      <p class="mt-6 text-lg md:text-xl text-surface-800/60 max-w-2xl mx-auto leading-relaxed animate-slide-up delay-100">
        **HPAI (Healing Powers Angel Investing)** is a proposed tokenized impact angel fund focused on backing early-stage AI and blockchain projects aligned with human health, consciousness, and abundance. The fund issues on-chain RWA (real-world asset) tokens representing LP interests in a regulated investment vehicle, offering investors fractional ownership, transparency, and potential secondary liquidity while targeting deals that demonstrate both financial return and measurable positive impact. HPAI differentiates itself through three core pillars — frontier AI/blockchain, human health & wellness, and positive media/narrative — using AI-assisted sourcing and due diligence, programmable impact covenants, and a community-driven go-to-market strategy targeting crypto-savvy angels, conscious capital allocators, and Web3 participants who want a compliant, purpose-driven co-investment structure for the emerging intersection of tokenization and impact investing.
      </p>
      <div class="mt-10 animate-slide-up delay-200">
        <a href="#cta" class="inline-block px-8 py-3.5 bg-brand-500 text-white font-semibold rounded-lg hover:bg-brand-600 transition-colors text-base">
          Get Started
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="cta" class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl bg-brand-500 p-10 md:p-16 text-center">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white font-display">Ready to get started?</h2>
        <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto">Get in touch and see what we can do for you.</p>
        <a href="mailto:hello@example.com" class="mt-8 inline-block px-8 py-3.5 bg-white text-surface-900 font-semibold rounded-lg hover:bg-surface-100 transition-colors text-base">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Base>
